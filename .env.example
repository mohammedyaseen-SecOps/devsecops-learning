# Environment Configuration Template

## Development Environment (.env.local)

```bash
# Application Environment
NODE_ENV=development
APP_NAME=GRC Platform
APP_VERSION=1.0.0
LOG_LEVEL=debug
ENVIRONMENT=development

# Server Configuration
PORT=3000
HOST=localhost
API_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:3001

# Database - Master (Platform)
DATABASE_TYPE=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=grc_admin
DATABASE_PASSWORD=local_dev_password_change_in_prod
DATABASE_NAME=grc_master
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_LOGGING=true

# Database - Tenant (Multi-Tenant)
TENANT_DATABASE_TYPE=postgresql
TENANT_DATABASE_HOST=localhost
TENANT_DATABASE_PORT=5433
TENANT_DATABASE_USERNAME=grc_tenant
TENANT_DATABASE_PASSWORD=local_dev_password_change_in_prod
TENANT_DATABASE_NAME=grc_tenant_acme
TENANT_DATABASE_POOL_MIN=2
TENANT_DATABASE_POOL_MAX=10

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=5000
REDIS_POOL_SIZE=10

# Session Management
SESSION_SECRET=dev_session_secret_change_in_prod
SESSION_TIMEOUT=3600
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# JWT Authentication
JWT_SECRET=dev_jwt_secret_change_in_prod
JWT_EXPIRATION=86400
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_prod
JWT_REFRESH_EXPIRATION=604800

# Encryption
ENCRYPTION_KEY=dev_encryption_key_change_in_prod
ENCRYPTION_ALGORITHM=aes-256-gcm

# OAuth / SAML Configuration
OAUTH_PROVIDERS=okta,azuread,google
OKTA_ORG_URL=https://dev-12345.okta.com
OKTA_CLIENT_ID=your_okta_client_id
OKTA_CLIENT_SECRET=your_okta_client_secret
OKTA_API_TOKEN=your_okta_api_token
SAML_ENABLED=false
SAML_CERT_PATH=/path/to/cert.pem
SAML_KEY_PATH=/path/to/key.pem

# MFA (Multi-Factor Authentication)
MFA_ENABLED=false
MFA_ISSUER=GRC Platform
TOTP_WINDOW=1

# Email Configuration (Optional - for development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@grc-platform.local
SMTP_USE_TLS=false

# File Storage
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=./uploads
FILE_UPLOAD_MAX_SIZE=52428800
FILE_ALLOWED_TYPES=pdf,docx,xlsx,jpg,png,csv,json

# AWS Integration (Optional)
AWS_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=grc-reports-dev
AWS_S3_PREFIX=dev/

# Feature Flags
FEATURE_AI_SCORING=false
FEATURE_ADVANCED_REPORTING=false
FEATURE_CUSTOM_FORMS=true
FEATURE_INTEGRATIONS=true
FEATURE_WEBHOOKS=true
FEATURE_AUDIT_LOGGING=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_KEY_PREFIX=ratelimit:

# Logging
LOG_FORMAT=json
LOG_OUTPUT=console,file
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILE_SIZE=10485760
LOG_MAX_FILES=5

# Monitoring (Optional)
SENTRY_ENABLED=false
SENTRY_DSN=
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_APP_KEY=

# CORS Configuration
CORS_ORIGIN=http://localhost:*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Security Headers
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false
CSP_ENABLED=true

# API Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs
SWAGGER_TITLE=GRC Platform API
SWAGGER_VERSION=1.0.0

# Database Migration
DB_MIGRATION_AUTO=true
DB_SEED_DATA=true
DB_SEED_TEST_DATA=false

# Elasticsearch (Optional - for advanced search)
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=grc-

# Message Queue (Optional)
MESSAGE_QUEUE_TYPE=none
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=grc-dev
RABBITMQ_URL=amqp://localhost:5672

# Timezone
TZ=UTC

# Debug Mode
DEBUG=*:*
DEBUG_TRACE=false
DEBUG_SQL=false

# Testing Configuration
TEST_DATABASE_NAME=grc_test
TEST_REDIS_DB=15
TEST_SEED_DATA=true

# API Keys (Development Only)
API_KEY_SUPER_ADMIN=dev_super_admin_key_change_in_prod
API_KEY_SERVICE_ACCOUNT=dev_service_account_key_change_in_prod
```

## Staging Environment (.env.staging)

```bash
NODE_ENV=staging
APP_NAME=GRC Platform (Staging)
APP_VERSION=1.0.0
LOG_LEVEL=info
ENVIRONMENT=staging

PORT=3000
HOST=0.0.0.0
API_URL=https://staging-api.grc-platform.com/api
FRONTEND_URL=https://staging.grc-platform.com

DATABASE_HOST=grc-staging.c9akciq32.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_USERNAME=grc_admin
DATABASE_PASSWORD=${STAGING_DB_PASSWORD}
DATABASE_NAME=grc_master_staging
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=25
DATABASE_SSL=require

TENANT_DATABASE_HOST=grc-staging-tenant.c9akciq32.us-east-1.rds.amazonaws.com
TENANT_DATABASE_PORT=5432
TENANT_DATABASE_USERNAME=grc_tenant
TENANT_DATABASE_PASSWORD=${STAGING_TENANT_DB_PASSWORD}
TENANT_DATABASE_POOL_MIN=5
TENANT_DATABASE_POOL_MAX=25
TENANT_DATABASE_SSL=require

REDIS_HOST=grc-staging-cache.5xxx4x.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=${STAGING_REDIS_PASSWORD}
REDIS_DB=0
REDIS_SSL=true

SESSION_SECRET=${STAGING_SESSION_SECRET}
JWT_SECRET=${STAGING_JWT_SECRET}
JWT_EXPIRATION=86400
ENCRYPTION_KEY=${STAGING_ENCRYPTION_KEY}

OKTA_ORG_URL=https://company.okta.com
OKTA_CLIENT_ID=${STAGING_OKTA_CLIENT_ID}
OKTA_CLIENT_SECRET=${STAGING_OKTA_CLIENT_SECRET}

MFA_ENABLED=true
TOTP_WINDOW=1

SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=${STAGING_SMTP_USER}
SMTP_PASSWORD=${STAGING_SMTP_PASSWORD}
SMTP_FROM=noreply@staging.grc-platform.com
SMTP_USE_TLS=true

FILE_STORAGE_TYPE=s3
AWS_ENABLED=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${STAGING_AWS_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${STAGING_AWS_SECRET_KEY}
AWS_S3_BUCKET=grc-reports-staging
AWS_S3_PREFIX=staging/

FEATURE_AI_SCORING=true
FEATURE_ADVANCED_REPORTING=true
FEATURE_CUSTOM_FORMS=true
FEATURE_INTEGRATIONS=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=5000
RATE_LIMIT_WINDOW=60000

SENTRY_ENABLED=true
SENTRY_DSN=${STAGING_SENTRY_DSN}

ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_HOST=grc-staging-es.us-east-1.es.amazonaws.com
ELASTICSEARCH_PORT=443
ELASTICSEARCH_USERNAME=${STAGING_ES_USERNAME}
ELASTICSEARCH_PASSWORD=${STAGING_ES_PASSWORD}
ELASTICSEARCH_INDEX_PREFIX=grc-staging-

MESSAGE_QUEUE_TYPE=kafka
KAFKA_BROKERS=kafka-broker-1:9092,kafka-broker-2:9092,kafka-broker-3:9092
KAFKA_GROUP_ID=grc-staging

TZ=UTC
```

## Production Environment (.env.production)

```bash
NODE_ENV=production
APP_NAME=GRC Platform
APP_VERSION=1.0.0
LOG_LEVEL=error
ENVIRONMENT=production

PORT=3000
HOST=0.0.0.0
API_URL=https://api.grc-platform.com/v1
FRONTEND_URL=https://grc-platform.com

DATABASE_HOST=${PROD_DB_HOST}
DATABASE_PORT=5432
DATABASE_USERNAME=${PROD_DB_USERNAME}
DATABASE_PASSWORD=${PROD_DB_PASSWORD}
DATABASE_NAME=grc_master
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_SSL=require
DATABASE_REPLICA_HOST=${PROD_DB_REPLICA_HOST}

TENANT_DATABASE_HOST=${PROD_TENANT_DB_HOST}
TENANT_DATABASE_PORT=5432
TENANT_DATABASE_USERNAME=${PROD_TENANT_DB_USERNAME}
TENANT_DATABASE_PASSWORD=${PROD_TENANT_DB_PASSWORD}
TENANT_DATABASE_POOL_MIN=10
TENANT_DATABASE_POOL_MAX=50
TENANT_DATABASE_SSL=require

REDIS_HOST=${PROD_REDIS_HOST}
REDIS_PORT=6379
REDIS_PASSWORD=${PROD_REDIS_PASSWORD}
REDIS_DB=0
REDIS_SSL=true
REDIS_POOL_SIZE=20

SESSION_SECRET=${PROD_SESSION_SECRET}
JWT_SECRET=${PROD_JWT_SECRET}
JWT_EXPIRATION=86400
ENCRYPTION_KEY=${PROD_ENCRYPTION_KEY}

OKTA_ORG_URL=https://company.okta.com
OKTA_CLIENT_ID=${PROD_OKTA_CLIENT_ID}
OKTA_CLIENT_SECRET=${PROD_OKTA_CLIENT_SECRET}

MFA_ENABLED=true
TOTP_WINDOW=1

SMTP_HOST=${PROD_SMTP_HOST}
SMTP_PORT=587
SMTP_USERNAME=${PROD_SMTP_USERNAME}
SMTP_PASSWORD=${PROD_SMTP_PASSWORD}
SMTP_FROM=noreply@grc-platform.com
SMTP_USE_TLS=true

FILE_STORAGE_TYPE=s3
AWS_ENABLED=true
AWS_REGION=us-east-1
AWS_SECONDARY_REGION=eu-west-1
AWS_ACCESS_KEY_ID=${PROD_AWS_ACCESS_KEY}
AWS_SECRET_ACCESS_KEY=${PROD_AWS_SECRET_KEY}
AWS_S3_BUCKET=grc-reports-prod
AWS_S3_PREFIX=prod/
AWS_S3_CROSS_REGION_REPLICATION=true

FEATURE_AI_SCORING=true
FEATURE_ADVANCED_REPORTING=true
FEATURE_CUSTOM_FORMS=true
FEATURE_INTEGRATIONS=true
FEATURE_WEBHOOKS=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=10000
RATE_LIMIT_WINDOW=60000

SENTRY_ENABLED=true
SENTRY_DSN=${PROD_SENTRY_DSN}
SENTRY_ENVIRONMENT=production
SENTRY_TRACE_SAMPLE_RATE=0.1

ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_HOST=${PROD_ES_HOST}
ELASTICSEARCH_PORT=443
ELASTICSEARCH_USERNAME=${PROD_ES_USERNAME}
ELASTICSEARCH_PASSWORD=${PROD_ES_PASSWORD}
ELASTICSEARCH_INDEX_PREFIX=grc-prod-
ELASTICSEARCH_SHARDS=3
ELASTICSEARCH_REPLICAS=2

MESSAGE_QUEUE_TYPE=kafka
KAFKA_BROKERS=${PROD_KAFKA_BROKERS}
KAFKA_GROUP_ID=grc-prod
KAFKA_ZOOKEEPER_HOSTS=${PROD_ZOOKEEPER_HOSTS}

CORS_ORIGIN=https://grc-platform.com
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_CREDENTIALS=true

HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
CSP_ENABLED=true

LOG_FORMAT=json
LOG_OUTPUT=file
LOG_FILE_PATH=/var/log/grc/app.log
LOG_MAX_FILE_SIZE=104857600
LOG_MAX_FILES=10

TZ=UTC
```

## Configuration Notes

### Development
- Use local mock services
- Enable debug logging
- Disable MFA
- Allow HTTP connections
- Use local file storage

### Staging
- Use realistic data (sanitized production data)
- Enable full monitoring
- Enable MFA for admins only
- Use SSL certificates
- Test third-party integrations

### Production
- Use encrypted secrets (Vault/AWS Secrets Manager)
- Enable all security features
- Enable comprehensive monitoring
- Use multi-region replication
- Enforce SSL/TLS
- Disable debug logging
- Enable audit logging
- Implement rate limiting

## Secret Management

Secrets should **NEVER** be committed to version control.

### Development
- Use `.env.local` (git ignored)
- Use simple passwords for local testing
- Store in `.env.local` only

### Staging/Production
- Use AWS Secrets Manager or HashiCorp Vault
- Rotate secrets every 30 days (critical secrets every 7 days)
- Use IAM roles for service authentication
- Implement automated secret rotation

### Accessing Secrets
```bash
# Using AWS Secrets Manager
aws secretsmanager get-secret-value --secret-id grc-staging-secrets

# Using HashiCorp Vault
vault kv get -format=json secret/grc/staging > .env.staging.vault
```


{
  "name": "grc-platform-backend",
  "version": "1.0.0",
  "description": "Enterprise GRC SaaS Platform - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --require tsconfig-paths/register src/index.ts",
    "dev:debug": "DEBUG=* ts-node-dev --respawn --transpile-only --require tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start dist/index.js --name 'grc-api'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e --runInBand",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "db:migrate": "ts-node --require tsconfig-paths/register src/cli/migrate.ts run",
    "db:migrate:status": "ts-node --require tsconfig-paths/register src/cli/migrate.ts status",
    "db:migrate:rollback": "ts-node --require tsconfig-paths/register src/cli/migrate.ts rollback",
    "db:migrate:reset": "ts-node --require tsconfig-paths/register src/cli/migrate.ts reset",
    "db:migrate:fresh": "ts-node --require tsconfig-paths/register src/cli/migrate.ts fresh",
    "db:seed": "ts-node --require tsconfig-paths/register src/cli/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "grc",
    "governance",
    "risk",
    "compliance",
    "saas",
    "multi-tenant"
  ],
  "author": "GRC Platform Team",
  "license": "PROPRIETARY",
  "dependencies": {
    "axios": "^1.3.4",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.7.0",
    "express-slow-down": "^1.6.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.0",
    "joi": "^17.9.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "passport": "^0.6.0",
    "passport-oauth2": "^1.7.0",
    "passport-saml": "^3.2.1",
    "pg": "^8.10.0",
    "redis": "^4.6.5",
    "sequelize": "^6.28.0",
    "sequelize-cli": "^6.6.0",
    "uuid": "^9.0.0",
    "validator": "^13.9.0",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/express-slow-down": "^1.3.5",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.5",
    "@types/node": "^18.15.11",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.41.0",
    "jest": "^29.5.0",
    "knex": "^2.5.1",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
